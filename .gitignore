```gitignore
# -------------------------------------------------------
# Python
# -------------------------------------------------------
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so

# Virtual Environment
venv/
.venv/
env/

# Environment Variables
.env
.env.*

# -------------------------------------------------------
# IDE
# -------------------------------------------------------

# VS Code
.vscode/

# PyCharm
.idea/

# -------------------------------------------------------
# Operating System
# -------------------------------------------------------

# Windows
Thumbs.db
Desktop.ini

# macOS
.DS_Store

# -------------------------------------------------------
# Logs
# -------------------------------------------------------

*.log
logs/
data/logs/

# -------------------------------------------------------
# Jupyter
# -------------------------------------------------------

.ipynb_checkpoints/

# -------------------------------------------------------
# Python Build
# -------------------------------------------------------

build/
dist/
*.egg-info/

# -------------------------------------------------------
# Test / Coverage
# -------------------------------------------------------

.pytest_cache/
.coverage
htmlcov/

# -------------------------------------------------------
# Azure
# -------------------------------------------------------

.azure/

# -------------------------------------------------------
# Secrets / Keys
# -------------------------------------------------------

*.pem
*.key
*.crt
*.pfx

# -------------------------------------------------------
# Temporary files
# -------------------------------------------------------

*.tmp
*.temp

# -------------------------------------------------------
# Data files to ignore (optional)
# -------------------------------------------------------

# Uncomment these only if datasets become huge.
# data/raw/*.csv
# data/processed/*.csv
# data/archive/*
```
